---
---
<footer class="site-footer" role="contentinfo">
  <!-- Topographic wave grid -->
  <svg class="footer-wave" viewBox="0 0 1200 320" preserveAspectRatio="xMidYMid slice" aria-hidden="true" focusable="false">
    <defs>
      <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
        <path d="M 60 0 L 0 0 0 60" fill="none" stroke="white" stroke-width="0.5"/>
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#grid)"/>
    <!-- Wave lines -->
    <path d="M0,200 C150,160 300,240 450,200 C600,160 750,240 900,200 C1050,160 1150,220 1200,200" fill="none" stroke="white" stroke-width="0.8" opacity="0.6"/>
    <path d="M0,220 C200,180 350,260 500,220 C650,180 800,250 950,215 C1100,180 1160,230 1200,215" fill="none" stroke="white" stroke-width="0.5" opacity="0.4"/>
    <path d="M0,240 C100,210 280,270 430,240 C580,210 730,260 880,240 C1030,218 1140,248 1200,235" fill="none" stroke="white" stroke-width="0.4" opacity="0.3"/>
    <path d="M0,260 C180,235 330,278 480,255 C630,232 780,268 930,250 C1080,232 1160,255 1200,248" fill="none" stroke="white" stroke-width="0.3" opacity="0.2"/>
  </svg>

  <div class="container footer-inner">
    <span class="footer-monogram" aria-label="Tim Stäcker">T&thinsp;|&thinsp;S</span>

    <div class="footer-center">
      <p class="footer-copy">© 2026 Tim Stäcker</p>
      <nav class="footer-links" aria-label="Footer Navigation">
        <button class="footer-impressum-btn" id="impressum-btn" aria-haspopup="dialog">Impressum</button>
      </nav>
    </div>

    <span class="footer-monogram" aria-hidden="true" style="opacity:0;pointer-events:none;">T&thinsp;|&thinsp;S</span>
  </div>
  <div class="footer-syslog-wrap" aria-hidden="true">
    <p class="footer-syslog" id="footer-syslog"></p>
  </div>
</footer>

<div class="konami-toast" id="konami-toast" role="status" aria-live="polite">
  Hanseatisch freigeschaltet.
</div>

<!-- Impressum Modal -->
<div class="impressum-overlay" id="impressum-overlay" role="dialog" aria-modal="true" aria-labelledby="impressum-title" hidden>
  <div class="impressum-card">
    <div class="impressum-header">
      <p class="section-label" id="impressum-title">Impressum</p>
      <button class="impressum-close" id="impressum-close" aria-label="Impressum schließen">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16" aria-hidden="true">
          <line x1="2" y1="2" x2="14" y2="14"/>
          <line x1="14" y1="2" x2="2" y2="14"/>
        </svg>
      </button>
    </div>

    <div class="impressum-body">
      <h2 class="impressum-section-title">Angaben gemäß §5 TMG</h2>
      <p>Tim Stäcker<br>
      Am Liss 1b<br>
      83026 Rosenheim<br>
      Deutschland</p>

      <h2 class="impressum-section-title">Kontakt</h2>
      <p>E-Mail: <a href="mailto:impressum@timstaecker.com">impressum@timstaecker.com</a></p>

      <h2 class="impressum-section-title">Haftung für Inhalte</h2>
      <p>Die Inhalte dieser Seite wurden mit größtmöglicher Sorgfalt erstellt. Für die Richtigkeit, Vollständigkeit und Aktualität der Inhalte kann jedoch keine Gewähr übernommen werden.</p>
    </div>
  </div>
</div>
