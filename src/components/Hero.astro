---
---
<section class="hero container" aria-label="Hero">
  <div class="hero-inner">
    <div class="hero-text">
      <span class="hero-eyebrow">Moin, ich bin</span>

      <h1 class="hero-name">Tim&nbsp;Stäcker</h1>

      <p class="hero-tagline">Zahlen. Prozesse. Systeme.</p>

      <p class="hero-body">
        Ich arbeite mit Zahlen, Prozessen und Systemen. Meistens dort,
        wo viele Zusammenhänge aufeinandertreffen und trotzdem Klarheit
        entstehen muss.
      </p>

      <span class="hero-scroll" aria-hidden="true">
        <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <line x1="7" y1="1" x2="7" y2="13"/>
          <polyline points="3,9 7,13 11,9"/>
        </svg>
        Scroll
      </span>

      <blockquote class="hero-quote" id="hero-quote" aria-live="polite"></blockquote>
    </div>

    <div class="hero-visual">
      <div class="hero-image-wrap">
        <img
          src="/elphi-hero.png"
          alt="Elbphilharmonie am Hamburger Hafen"
          class="hero-img"
          width="600"
          height="520"
          loading="eager"
          decoding="sync"
        />
      </div>
    </div>
  </div>
</section>
