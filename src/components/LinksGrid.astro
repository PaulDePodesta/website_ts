---
const links = [
  {
    icon: 'github',
    title: 'GitHub',
    desc: 'Projekte, Code und technische Experimente.',
    tag: 'Code',
    href: 'https://github.com/PaulDePodesta/',
    external: true,
  },
  {
    icon: 'linkedin',
    title: 'LinkedIn',
    desc: 'Beruflicher Werdegang und Netzwerk.',
    tag: 'Netzwerk',
    href: 'https://www.linkedin.com/in/tim-st%C3%A4cker-23749b122/',
    external: true,
  },
  {
    icon: 'doc',
    title: 'Akademische Arbeit',
    desc: 'Nutzenpotenziale von maschinellem Lernen für moderne Ansätze zur Unternehmensbewertung',
    tag: 'PDF',
    href: '/Tim%20Staecker_Masterarbeit.pdf',
    external: false,
  },
  {
    icon: 'ball',
    title: 'Football Finance Blog',
    desc: 'Gedanken zu Fußball aus finanzieller und strategischer Perspektive.',
    tag: 'Blog',
    href: 'https://example.com/',
    external: true,
  },
];
---

<section class="links-section" aria-labelledby="links-label">
  <div class="container">
    <p class="section-label" id="links-label">Links &amp; Projekte</p>

    <div class="links-grid" role="list">
      {links.map((l) => (
        <a
          href={l.href}
          class="link-card"
          role="listitem"
          {...l.external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
          aria-label={`${l.title} — ${l.desc}`}
        >
          <!-- Icon -->
          {l.icon === 'github' && (
            <svg class="link-card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
            </svg>
          )}
          {l.icon === 'linkedin' && (
            <svg class="link-card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
              <rect x="2" y="9" width="4" height="12"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          )}
          {l.icon === 'doc' && (
            <svg class="link-card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14,2 14,8 20,8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
              <polyline points="10,9 9,9 8,9"/>
            </svg>
          )}
          {l.icon === 'ball' && (
            <svg class="link-card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/>
              <path d="M2 12h20"/>
            </svg>
          )}

          <div class="link-card-body">
            <span class="link-card-title">{l.title}</span>
            <p class="link-card-desc">{l.desc}</p>
          </div>

          <div class="link-card-footer">
            <span class="link-card-tag">{l.tag}</span>
            <svg class="link-card-arrow" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <line x1="2" y1="12" x2="12" y2="2"/>
              <polyline points="5,2 12,2 12,9"/>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
